# Copy to .env.local. Never commit .env.local or a real key.
OPENAI_API_KEY=
OPENAI_ORG_ID=

# Optional overrides.
OPENAI_REALTIME_TRANSLATION_MODEL=gpt-realtime-translate
OPENAI_REALTIME_VOICE=marin
HOST=127.0.0.1
PORT=8799

# Public-source defaults.
# Leave bridge auth enabled for the Chrome extension. Print the local token with:
# npm run bridge:token
SOTTO_DISABLE_BRIDGE_AUTH=0
SOTTO_ENABLE_DEBUG_ROUTES=0
